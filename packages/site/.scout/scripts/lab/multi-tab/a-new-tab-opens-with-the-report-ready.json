[
  {
    "kind": "navigate",
    "url": "/"
  },
  {
    "kind": "click",
    "target": {
      "css": "body:nth-of-type(1) > header:nth-of-type(1) > div:nth-of-type(1) > nav:nth-of-type(1) > a:nth-of-type(4)",
      "description": "link \"Lab\""
    }
  },
  {
    "kind": "screenshot",
    "label": "lab-page-loaded"
  },
  {
    "kind": "click",
    "target": {
      "role": "button",
      "name": "Open the report in a new tab",
      "description": "button \"Open the report in a new tab\""
    }
  },
  {
    "kind": "switchTab",
    "urlGlob": "**/lab/report/**"
  },
  {
    "kind": "assertUrl",
    "pattern": "/lab/report/"
  },
  {
    "kind": "assertVisible",
    "text": "Report ready"
  },
  {
    "kind": "screenshot",
    "label": "new-tab-report-ready"
  },
  {
    "kind": "assertNoConsoleErrors"
  }
]
