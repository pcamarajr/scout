---
// Scout — 404 page-view
//
// Generated by astro-builder (seo-conventions skill). ONE view serves every
// locale; it resolves its own locale via Astro.currentLocale like any
// page-view. The thin wrapper lives at src/pages/404.astro.
import BaseLayout from "@layouts/BaseLayout.astro";
import { createTranslator } from "@lib/i18n";
import { buildHomeUrl } from "@lib/urls";

const locale = Astro.currentLocale ?? "en";
const tl = createTranslator(Astro.currentLocale);
---

<BaseLayout title={tl("notFound.title")} description={tl("notFound.description")}>
  <h1>{tl("notFound.title")}</h1>
  <p>{tl("notFound.body")}</p>
  <a href={buildHomeUrl(locale)}>{tl("notFound.backHome")}</a>
</BaseLayout>
