---
// Scout — single doc page-view
//
// Renders one docs entry inside the docs shell: a breadcrumb, the title and
// lede, then the MDX body in the serif reading column. The shell chrome
// (sidebar + "On this page" TOC) lives in DocsLayout; this view owns the
// reading column and passes the entry's headings up for the TOC.
// src/pages/docs/[...slug].astro is the thin route wrapper.
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import DocsLayout from "@layouts/DocsLayout.astro";
import { createTranslator } from "@lib/i18n";
import { buildLocaleUrl } from "@lib/urls";

interface Props {
  entry: CollectionEntry<"docs">;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const locale = Astro.currentLocale ?? "en";
const tl = createTranslator(Astro.currentLocale);

const slug = entry.id.replace(/^[^/]+\//, "");
const docsHref = buildLocaleUrl(locale, "docs");
const label = entry.data.sidebarLabel ?? entry.data.title;
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  activeSlug={slug}
  headings={headings}
>
  <article class="doc" data-pagefind-body>
    <nav class="breadcrumb" aria-label="Breadcrumb" data-pagefind-ignore>
      <a href={docsHref}>{tl("docs.title")}</a>
      <span class="sep" aria-hidden="true">/</span>
      <span>{entry.data.group}</span>
      <span class="sep" aria-hidden="true">/</span>
      <span class="current">{label}</span>
    </nav>
    <h1>{entry.data.title}</h1>
    <p class="lead">{entry.data.description}</p>
    <div class="prose">
      <Content />
    </div>
  </article>
</DocsLayout>

<style>
  .doc {
    padding-block: var(--space-2xl) var(--space-3xl);
    max-width: 48rem;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-subtle);
    margin-block-end: var(--space-lg);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-primary);
  }

  .breadcrumb .sep {
    margin-inline: var(--space-sm);
    color: var(--color-border-strong);
  }

  .breadcrumb .current {
    color: var(--color-text);
  }

  .doc h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-3xl);
    letter-spacing: -0.015em;
    line-height: 1.1;
    margin: 0 0 var(--space-md);
  }

  .lead {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-2xl);
    max-width: 60ch;
  }

  /* ── reading prose (serif signals measured reading) ── */
  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-xl);
    letter-spacing: -0.01em;
    margin-block: var(--space-2xl) var(--space-md);
    scroll-margin-block-start: calc(60px + var(--space-md));
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-lg);
    margin-block: var(--space-xl) var(--space-sm);
    scroll-margin-block-start: calc(60px + var(--space-md));
  }

  .prose :global(p),
  .prose :global(li) {
    font-family: var(--font-serif);
    font-size: 1.075rem;
    line-height: 1.72;
    color: var(--color-text);
  }

  .prose :global(p) {
    margin-block: 0 var(--space-md);
    max-width: 66ch;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-block: 0 var(--space-md);
    padding-inline-start: var(--space-lg);
    max-width: 66ch;
  }

  .prose :global(li) {
    margin-block-end: var(--space-xs);
  }

  .prose :global(a) {
    color: var(--color-primary);
    text-underline-offset: 0.15em;
  }

  /* inline code */
  .prose :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.84em;
    background: var(--color-surface-sunken);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1px 6px;
    color: var(--color-text);
  }

  /* code blocks — Shiki ships its own dark background; we add the frame */
  .prose :global(pre) {
    margin-block: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow-x: auto;
    font-size: var(--text-mono);
    line-height: 1.7;
  }

  .prose :global(pre) :global(code) {
    font-family: var(--font-mono);
  }

  /* blockquotes → lens-tinted callout */
  .prose :global(blockquote) {
    margin-block: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    border: 1px solid color-mix(in srgb, var(--color-primary) 35%, var(--color-border));
    border-inline-start: 3px solid var(--color-primary);
    border-radius: var(--radius-md);
    background: var(--color-primary-soft);
  }

  .prose :global(blockquote) :global(p) {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    max-width: none;
  }

  .prose :global(blockquote) :global(p:not(:last-child)) {
    margin-block-end: var(--space-sm);
  }

  /* GFM tables */
  .prose :global(table) {
    inline-size: 100%;
    border-collapse: collapse;
    margin-block: var(--space-lg);
    font-family: var(--font-body);
    font-size: var(--text-sm);
  }

  .prose :global(th),
  .prose :global(td) {
    text-align: start;
    padding: var(--space-sm) var(--space-md);
    border-block-end: 1px solid var(--color-border);
    vertical-align: top;
  }

  .prose :global(th) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .prose :global(td) {
    color: var(--color-text-muted);
  }

  .prose :global(hr) {
    margin-block: var(--space-2xl);
    border: 0;
    border-block-start: 1px solid var(--color-border);
  }
</style>
