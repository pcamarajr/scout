---
// Scout — single doc page-view
//
// Generated by astro-builder. Renders one docs entry's MDX body inside the
// reading column. src/pages/docs/[...slug].astro is the thin wrapper that
// resolves the entry from the route and passes it in.
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

interface Props {
  entry: CollectionEntry<"docs">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="doc">
    <h1>{entry.data.title}</h1>
    <p class="lead">{entry.data.description}</p>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .doc {
    max-width: 44rem;
    margin-inline: auto;
    padding: var(--space-2xl) var(--space-lg);
    font-family: var(--font-serif);
  }

  .lead {
    margin-block: var(--space-md) var(--space-xl);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .prose :global(h2) {
    margin-block: var(--space-xl) var(--space-md);
  }

  .prose :global(h3) {
    margin-block: var(--space-lg) var(--space-sm);
  }

  .prose :global(p) {
    margin-block-end: var(--space-md);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-block-end: var(--space-md);
    padding-inline-start: var(--space-lg);
  }

  .prose :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    overflow-x: auto;
    margin-block-end: var(--space-md);
  }
</style>
