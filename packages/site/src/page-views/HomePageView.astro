---
// Scout — home page-view
//
// Generated by astro-builder. All landing markup, data, and translations live
// here; src/pages/index.astro is a thin wrapper. Faithful port of the locked
// landing (design/site.html + design/CONTENT.md §3): hero with the calibrated
// instrument, the "bottleneck moved" manifesto band, the self-healing loop
// (01→04 + terminal reading), and the verdict → exit-code contract. Honesty
// guardrails (#333): cheap deterministic replay is a supporting nicety, never
// the headline moat — the pitch is the no-code / unattended-heal / gate combo.
import HeroInstrument from "@components/HeroInstrument.astro";
import VerdictPlate from "@components/VerdictPlate.astro";
import VerdictTable from "@components/VerdictTable.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { createTranslator } from "@lib/i18n";
import { buildDocsHomeUrl } from "@lib/urls";

const locale = Astro.currentLocale ?? "en";
const tl = createTranslator(Astro.currentLocale);

const docsHref = buildDocsHomeUrl(locale);

// The "now" manifesto column carries the lens tint as the resolving step.
const COLUMNS = [
  { key: tl("manifesto.beforeKey"), heading: tl("manifesto.beforeHeading"), body: tl("manifesto.beforeBody"), focus: false },
  { key: tl("manifesto.nowKey"), heading: tl("manifesto.nowHeading"), body: tl("manifesto.nowBody"), focus: false },
  { key: tl("manifesto.withScoutKey"), heading: tl("manifesto.withScoutHeading"), body: tl("manifesto.withScoutBody"), focus: true },
] as const;
---

<BaseLayout title={tl("home.title")} description={tl("home.intro")}>
  {/* ── hero ─────────────────────────────────────────────────── */}
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{tl("home.eyebrow")}</p>
        <h1>
          {tl("home.h1Lead")}<br />{tl("home.h1Tail")}{" "}
          <span class="focus">{tl("home.h1Focus")}</span>.
        </h1>
        <p class="sub">
          {tl("home.intro")} <b>{tl("home.subEmphasis")}</b>
        </p>

        <div class="cta-row">
          <a class="btn btn-primary" href={docsHref}>
            {tl("home.ctaGetStarted")} <span class="arr" aria-hidden="true">→</span>
          </a>
          <div class="install">
            <span class="prompt" aria-hidden="true">{tl("home.installPrompt")}</span>
            <code data-install-cmd>{tl("home.install")}</code>
            <button
              type="button"
              class="copy"
              data-copy
              data-copied-label={tl("home.copiedLabel")}
              aria-label={tl("home.copyAria")}
            >
              <span data-copy-label>{tl("home.copyLabel")}</span>
            </button>
          </div>
        </div>

        <dl class="hero-stats">
          <div class="stat">
            <dt>{tl("home.statFilesValue")}</dt>
            <dd>{tl("home.statFilesLabel")}</dd>
          </div>
          <div class="stat">
            <dt>{tl("home.statSentenceValue")}</dt>
            <dd>{tl("home.statSentenceLabel")}</dd>
          </div>
          <div class="stat">
            <dt>{tl("home.statHealValue")}</dt>
            <dd>{tl("home.statHealLabel")}</dd>
          </div>
        </dl>

        <div class="legend">
          <span class="lab">{tl("home.verdictLegendCaption")}</span>
          <ul aria-label={tl("home.verdictLegendLabel")}>
            <li><VerdictPlate verdict="verified" size="sm" /></li>
            <li><VerdictPlate verdict="partial" size="sm" /></li>
            <li><VerdictPlate verdict="failed" size="sm" /></li>
            <li><VerdictPlate verdict="blocked" size="sm" /></li>
          </ul>
        </div>
      </div>

      <HeroInstrument />
    </div>
  </section>

  {/* ── manifesto · the bottleneck moved ─────────────────────── */}
  <section class="band marker" id="manifesto">
    <div class="wrap">
      <span class="marker-tag">// <b>{tl("manifesto.tag")}</b></span>
      <p class="eyebrow">{tl("manifesto.eyebrow")}</p>
      <h2>{tl("manifesto.titleLead")} <em>{tl("manifesto.titleEmph")}</em>.</h2>
      <div class="cols">
        {
          COLUMNS.map((col) => (
            <div class:list={["col", { "col--focus": col.focus }]}>
              <p class="k">{col.key}</p>
              <h3>{col.heading}</h3>
              <p>{col.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ── feature · the self-healing loop ──────────────────────── */}
  <section class="feature marker" id="feature">
    <div class="wrap">
      <span class="marker-tag">// <b>{tl("feature.tag")}</b></span>
      <div class="feature-head">
        <p class="eyebrow">{tl("feature.eyebrow")}</p>
        <h2>{tl("feature.titleLead")} <em>{tl("feature.titleEmph")}</em></h2>
        <p class="lede">{tl("feature.lede")}</p>
      </div>

      <div class="loop">
        <ol class="steps" aria-label={tl("feature.stepsLabel")}>
          <li class="step">
            <span class="idx">01</span>
            <div>
              <h3>{tl("feature.step01Title")}</h3>
              <p>{tl("feature.step01Body")}</p>
              <div class="row"><span class="cost">{tl("feature.step01Cost")}</span></div>
            </div>
          </li>
          <li class="step">
            <span class="idx">02</span>
            <div>
              <h3>{tl("feature.step02Title")}</h3>
              <p>{tl("feature.step02Body")}</p>
              <div class="row">
                <VerdictPlate verdict="verified" size="sm" />
                <span class="cost">{tl("feature.step02Cost")}</span>
              </div>
            </div>
          </li>
          <li class="step">
            <span class="idx">03</span>
            <div>
              <h3>{tl("feature.step03Title")}</h3>
              <p>{tl("feature.step03Body")}</p>
              <div class="row"><span class="cost">{tl("feature.step03Cost")}</span></div>
            </div>
          </li>
          <li class="step step--heal">
            <span class="idx">04</span>
            <div>
              <h3>{tl("feature.step04Title")}</h3>
              <p>{tl("feature.step04Body")}</p>
              <div class="row">
                <VerdictPlate verdict="partial" size="sm" />
                <span class="cost cost--lens">{tl("feature.step04Cost")}</span>
              </div>
            </div>
          </li>
        </ol>

        <figure class="scope">
          <div class="scope-head">
            <span class="lamps"><i></i><i></i><i></i></span>
            <span class="title">{tl("feature.terminalTitle")}</span>
            <span class="reading">{tl("feature.terminalReading")}</span>
          </div>
          <div class="scope-body">
            <span class="ln"><span class="c-prompt">$</span> <span class="c-cmd">scout run checkout.spec</span></span>
            <span class="ln c-dim">scenario · "A returning user buys one item with a saved card"</span>
            <span class="ln">&nbsp;</span>
            <span class="ln"><span class="box">┌─</span> <span class="c-dim">cached script found · deterministic replay</span> <span class="meter">0 tokens</span></span>
            <span class="ln"><span class="box">│</span>  <span class="tick">✓</span> open /store <span class="meter">312ms</span></span>
            <span class="ln"><span class="box">│</span>  <span class="tick">✓</span> add Trail Mug to cart <span class="meter">88ms</span></span>
            <span class="ln"><span class="box">│</span>  <span class="tick">✓</span> pay with saved card •••• 4242 <span class="meter">140ms</span></span>
            <span class="ln"><span class="box">│</span>  <span class="tick">✓</span> order #A-2291 confirmed <span class="meter">61ms</span></span>
            <span class="ln"><span class="box">└─</span> <span class="c-dim">4 steps · 0 LLM calls</span></span>
            <span class="ln">&nbsp;</span>
            <span class="ln"><span class="tick">✅ verified</span> <span class="c-dim">· replayed without a model · exit 0</span></span>
            <span class="ln"><span class="c-prompt">$</span><span class="caret" aria-hidden="true"></span></span>
          </div>
          <figcaption class="sr-only">{tl("feature.terminalCaption")}</figcaption>
        </figure>
      </div>
    </div>
  </section>

  {/* ── verdict system · the CI contract ─────────────────────── */}
  <section class="verdicts marker" id="verdicts">
    <div class="wrap">
      <span class="marker-tag">// <b>{tl("verdict.tag")}</b></span>
      <div class="verdicts-head">
        <p class="eyebrow">{tl("verdict.eyebrow")}</p>
        <h2>{tl("verdict.titleLead")} <em>{tl("verdict.titleEmph")}</em></h2>
        <p class="lede">{tl("verdict.lede")}</p>
      </div>
      <div class="vtable-wrap">
        <VerdictTable />
      </div>
      <p class="footnote">{tl("verdict.footnote")}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: var(--space-lg);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brass-deep);
  }

  .eyebrow::before {
    content: "";
    width: 22px;
    height: 1px;
    background: currentColor;
  }

  /* ── markers ── */
  .marker {
    position: relative;
    border-block-start: 1px solid var(--color-border);
    padding-block: var(--space-3xl);
  }

  .marker-tag {
    position: absolute;
    inset-block-start: -1px;
    inset-inline-start: var(--space-lg);
    transform: translateY(-50%);
    background: var(--color-bg);
    padding-inline: var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .marker-tag b {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* ── hero ── */
  .hero {
    padding-block: var(--space-3xl);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .hero h1 {
    font-size: var(--text-mega);
    line-height: 1.02;
    letter-spacing: -0.018em;
    margin-block-start: var(--space-md);
  }

  .focus {
    font-style: italic;
    color: var(--color-primary);
  }

  .sub {
    max-width: 34ch;
    margin-block-start: var(--space-lg);
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--color-text-muted);
  }

  .sub b {
    color: var(--color-text);
    font-weight: 600;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
    margin-block-start: var(--space-xl);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-md);
    padding: 0.8rem 1.25rem;
    transition:
      transform var(--dur) var(--ease),
      background-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--color-on-failed);
    box-shadow: var(--shadow-md);
  }

  .btn-primary:hover {
    background: var(--color-primary-dark);
    color: var(--color-on-failed);
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: var(--shadow-lg);
  }

  .btn .arr {
    transition: transform var(--dur) var(--ease);
  }

  .btn-primary:hover .arr {
    transform: translateX(3px);
  }

  .install {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.7rem 0.85rem;
    font-family: var(--font-mono);
    font-size: var(--text-mono);
  }

  .install .prompt {
    color: var(--color-brass-deep);
  }

  .install code {
    color: var(--color-text);
  }

  .install .copy {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    transition: color var(--dur) var(--ease);
  }

  .install .copy:hover,
  .install .copy:focus-visible {
    color: var(--color-primary);
  }

  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xl);
    margin: 0;
    margin-block-start: var(--space-xl);
    padding-block-start: var(--space-md);
    border-block-start: 1px solid var(--color-border);
  }

  .stat dt {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }

  .stat dd {
    margin: 0;
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-subtle);
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-block-start: var(--space-lg);
  }

  .legend .lab {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .legend ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  /* ── manifesto band ── */
  .band h2,
  .feature-head h2,
  .verdicts-head h2 {
    font-size: var(--text-3xl);
    line-height: 1.08;
    letter-spacing: -0.015em;
    margin-block-start: var(--space-sm);
  }

  .band h2 em,
  .feature-head h2 em,
  .verdicts-head h2 em {
    font-style: italic;
    color: var(--color-brass-deep);
  }

  .cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-block-start: var(--space-xl);
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .col {
    background: var(--color-bg);
    padding: var(--space-xl) var(--space-lg);
  }

  .col--focus {
    background: var(--color-primary-soft);
  }

  .col .k {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-brass-deep);
  }

  .col h3 {
    font-size: var(--text-xl);
    letter-spacing: -0.01em;
    margin-block: var(--space-sm) var(--space-xs);
  }

  .col p {
    margin: 0;
    max-width: 34ch;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* ── feature / loop ── */
  .feature-head {
    max-width: 60ch;
  }

  .feature-head .lede {
    margin-block-start: var(--space-md);
    max-width: 54ch;
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .loop {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
    margin-block-start: var(--space-2xl);
  }

  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .step {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: var(--space-md);
    padding-block: var(--space-lg);
    border-block-start: 1px solid var(--color-border);
  }

  .step:last-child {
    border-block-end: 1px solid var(--color-border);
  }

  .step .idx {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    color: var(--color-brass-deep);
    padding-block-start: 3px;
  }

  .step h3 {
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-block-end: var(--space-xs);
  }

  .step p {
    margin: 0;
    max-width: 46ch;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-block-start: var(--space-sm);
  }

  .cost {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.2rem 0.6rem;
  }

  .cost--lens {
    color: var(--color-primary);
    border-color: color-mix(in oklch, var(--color-primary) 45%, transparent);
  }

  /* ── terminal scope ── */
  .scope {
    margin: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .scope-head {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.7rem var(--space-md);
    border-block-end: 1px solid var(--color-border);
    background: var(--color-surface-sunken);
  }

  .lamps {
    display: inline-flex;
    gap: 6px;
  }

  .lamps i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-border-strong);
  }

  .scope-head .title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .scope-head .reading {
    margin-inline-start: auto;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    color: var(--color-text-subtle);
  }

  .scope-body {
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    line-height: 1.85;
    padding: var(--space-md) var(--space-md) var(--space-lg);
    color: var(--color-text-muted);
    overflow-x: auto;
  }

  .scope-body .ln {
    display: block;
    white-space: pre;
  }

  .c-prompt { color: var(--color-brass); }
  .c-cmd { color: var(--color-text); }
  .c-dim { color: var(--color-text-subtle); }
  .box { color: var(--color-text-subtle); }
  .tick { color: var(--color-verified); }
  .meter { color: var(--color-brass-deep); }

  .caret {
    display: inline-block;
    width: 8px;
    height: 1.05em;
    vertical-align: text-bottom;
    margin-inline-start: 2px;
    background: var(--color-primary);
    animation: blink 1.1s steps(1) infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  /* ── verdict system ── */
  .verdicts-head {
    max-width: 60ch;
  }

  .verdicts-head .lede {
    margin-block-start: var(--space-md);
    max-width: 54ch;
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .vtable-wrap {
    margin-block-start: var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-sm) var(--space-lg);
    overflow-x: auto;
  }

  .footnote {
    margin-block-start: var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: var(--color-text-subtle);
  }

  /* ── responsive ── */
  @media (max-width: 60rem) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .loop {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 52rem) {
    .cols {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .caret {
      animation: none;
    }
  }
</style>

<script>
  // Install-command copy button — plain DOM, no island (interactivity ladder).
  const btn = document.querySelector<HTMLButtonElement>("[data-copy]");
  const cmd = document.querySelector<HTMLElement>("[data-install-cmd]");
  const label = document.querySelector<HTMLElement>("[data-copy-label]");

  if (btn && cmd && label) {
    const idle = label.textContent ?? "Copy";
    const done = btn.dataset.copiedLabel ?? "Copied";
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(cmd.textContent?.trim() ?? "");
        label.textContent = done;
        window.setTimeout(() => {
          label.textContent = idle;
        }, 1600);
      } catch {
        // clipboard blocked (insecure context / denied) — leave the label as-is
      }
    });
  }
</script>
