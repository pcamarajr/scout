---
// Scout — home page-view
//
// Generated by astro-builder. All landing markup, data, and translations live
// here; src/pages/index.astro is a thin wrapper. Minimal v1 hero — the full
// calibrated-instrument landing (design/site.html) lands in a follow-up.
import BaseLayout from "@layouts/BaseLayout.astro";
import { createTranslator } from "@lib/i18n";
import { buildLocaleUrl } from "@lib/urls";

const locale = Astro.currentLocale ?? "en";
const tl = createTranslator(Astro.currentLocale);
---

<BaseLayout title={tl("home.title")} description={tl("home.intro")}>
  <section class="hero">
    <p class="eyebrow">{tl("home.eyebrow")}</p>
    <h1>{tl("home.title")}</h1>
    <p class="intro">{tl("home.intro")}</p>
    <div class="actions">
      <a class="cta" href={buildLocaleUrl(locale, "docs")}>{tl("home.ctaDocs")}</a>
      <code class="install">{tl("home.install")}</code>
    </div>
    <dl class="stats">
      <div>
        <dt>0</dt>
        <dd>{tl("home.statFilesLabel")}</dd>
      </div>
      <div>
        <dt>1 sentence</dt>
        <dd>{tl("home.statSentenceLabel")}</dd>
      </div>
      <div>
        <dt>self-heal</dt>
        <dd>{tl("home.statHealLabel")}</dd>
      </div>
    </dl>
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: 56rem;
    margin-inline: auto;
    padding: var(--space-3xl) var(--space-lg);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brass-deep);
    margin-block-end: var(--space-md);
  }

  h1 {
    font-size: var(--text-mega);
  }

  .intro {
    max-width: 44rem;
    margin-block: var(--space-lg);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
    margin-block-end: var(--space-2xl);
  }

  .cta {
    background: var(--color-primary);
    color: var(--color-on-failed);
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    font-weight: 600;
  }

  .cta:hover {
    background: var(--color-primary-dark);
    color: var(--color-on-failed);
    text-decoration: none;
  }

  .install {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-sm) var(--space-md);
    font-size: var(--text-mono);
  }

  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xl);
    margin: 0;
    padding-block-start: var(--space-lg);
    border-block-start: 1px solid var(--color-border);
  }

  .stats dt {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-variant-numeric: tabular-nums;
  }

  .stats dd {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }
</style>
