---
// Scout — docs index page-view
//
// Generated by astro-builder. Lists published docs for the current locale,
// grouped by sidebar group, ordered by `order`. src/pages/docs/index.astro is
// the thin wrapper.
import BaseLayout from "@layouts/BaseLayout.astro";
import { getDocsByLang } from "@lib/content";
import { createTranslator } from "@lib/i18n";
import { buildDocUrl } from "@lib/urls";

const locale = Astro.currentLocale ?? "en";
const tl = createTranslator(Astro.currentLocale);

const docs = await getDocsByLang(locale);
const groups = ["Getting started", "Core concepts", "Reference"] as const;
---

<BaseLayout title={tl("docs.title")} description={tl("docs.description")}>
  <article class="docs-index">
    <h1>{tl("docs.title")}</h1>
    <p class="lead">{tl("docs.description")}</p>
    {
      groups.map((group) => {
        const entries = docs.filter((doc) => doc.data.group === group);
        if (entries.length === 0) return null;
        return (
          <section>
            <h2>{group}</h2>
            <ul>
              {entries.map((doc) => (
                <li>
                  <a href={buildDocUrl(doc.id, locale)}>
                    {doc.data.sidebarLabel ?? doc.data.title}
                  </a>
                  <span>{doc.data.description}</span>
                </li>
              ))}
            </ul>
          </section>
        );
      })
    }
  </article>
</BaseLayout>

<style>
  .docs-index {
    max-width: 48rem;
    margin-inline: auto;
    padding: var(--space-2xl) var(--space-lg);
  }

  .lead {
    margin-block: var(--space-md) var(--space-xl);
    color: var(--color-text-muted);
  }

  section {
    margin-block-end: var(--space-xl);
  }

  ul {
    list-style: none;
    padding: 0;
    margin-block-start: var(--space-md);
    display: grid;
    gap: var(--space-md);
  }

  li {
    display: grid;
    gap: var(--space-xs);
  }

  li a {
    font-weight: 600;
  }

  li span {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }
</style>
