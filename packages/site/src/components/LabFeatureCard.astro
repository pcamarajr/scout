---
// Scout — Lab feature card
//
// One feature of the gallery: header (eyebrow), title, blurb, a recorded demo
// of Scout verifying the scenario, then a body pairing the interactive surface
// (default slot) with the EXACT `.scout.md` scenario that runs against it. A
// docs link closes it.
//
// The demo is a static MP4 recorded with `scout --demo-video` (800×450) and
// committed under public/lab/demos/<file>.mp4 — regenerated only when the
// feature changes, never on every build. It answers "show me it working"
// without any runtime fetch or CI dependency; the verdict the project's own
// suite reaches lives in GitHub Actions, linked from the page.
import { createTranslator } from "@lib/i18n";
import type { LabFeature } from "@lib/lab";
import { buildDocUrl } from "@lib/urls";

interface Props {
  feature: LabFeature;
}

const { feature } = Astro.props;
const locale = Astro.currentLocale ?? "en";
const tl = createTranslator(Astro.currentLocale);

const docHref = `${buildDocUrl(feature.docSlug, locale)}${feature.docHash ? `#${feature.docHash}` : ""}`;
const videoSrc = `/lab/demos/${feature.file}.mp4`;
---

<article class="card" id={feature.file}>
  <header class="card-head">
    <p class="eyebrow">{feature.eyebrow}</p>
  </header>

  <h3>{feature.title}</h3>
  <p class="blurb">{feature.blurb}</p>

  <figure class="demo">
    <video
      class="demo-video"
      src={videoSrc}
      controls
      muted
      loop
      playsinline
      preload="metadata"
      width="800"
      height="450"
      aria-label={`${tl("lab.demoLabel")} — ${feature.title}`}></video>
    <figcaption>{tl("lab.demoCaption")}</figcaption>
  </figure>

  <div class="card-body">
    <section class="surface" aria-label={tl("lab.tryItLabel")}>
      <p class="panel-label">{tl("lab.tryIt")}</p>
      <div class="surface-stage">
        <slot />
      </div>
    </section>

    <section class="spec">
      <div class="spec-head">
        <span class="file">{feature.file}.scout.md</span>
        <span class="tag">{tl("lab.specTag")}</span>
      </div>
      <pre class="spec-body"><code>{feature.spec}</code></pre>
    </section>
  </div>

  <a class="doc-link" href={docHref}>
    {tl("lab.readDocs")} <span class="arr" aria-hidden="true">→</span>
  </a>
</article>

<style>
  .card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg);
    padding: var(--space-xl);
    scroll-margin-block-start: 80px;
  }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brass-deep);
  }

  .eyebrow::before {
    content: "";
    width: 22px;
    height: 1px;
    background: currentColor;
  }

  .card h3 {
    font-size: var(--text-xl);
    letter-spacing: -0.01em;
    margin-block: var(--space-md) var(--space-sm);
  }

  .blurb {
    max-width: 62ch;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* ── recorded demo (scout --demo-video, 800×450) ── */
  .demo {
    margin: var(--space-lg) 0 0;
  }

  .demo-video {
    display: block;
    inline-size: 100%;
    block-size: auto;
    aspect-ratio: 16 / 9;
    max-inline-size: 40rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface-sunken);
    box-shadow: var(--shadow-sm);
  }

  .demo figcaption {
    margin-block-start: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }

  .card-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-block-start: var(--space-lg);
  }

  .panel-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-block-end: var(--space-sm);
  }

  /* ── live surface ── */
  .surface-stage {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: flex-start;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    padding: var(--space-lg);
    min-block-size: 9.5rem;
  }

  /* ── spec panel ── the exact .scout.md, source of truth ── */
  .spec {
    display: flex;
    flex-direction: column;
  }

  .spec-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    padding: 0.5rem 0.8rem;
    border: 1px solid var(--color-border);
    border-block-end: 0;
    border-start-start-radius: var(--radius-md);
    border-start-end-radius: var(--radius-md);
    background: var(--color-surface-sunken);
  }

  .spec-head .file {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .spec-head .tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brass-deep);
  }

  .spec-body {
    flex: 1;
    margin: 0;
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-end-start-radius: var(--radius-md);
    border-end-end-radius: var(--radius-md);
    background: var(--color-surface);
    font-size: var(--text-mono);
    line-height: 1.7;
    color: var(--color-text-muted);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    tab-size: 2;
  }

  .spec-body code {
    font-family: var(--font-mono);
  }

  /* ── docs link ── */
  .doc-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-block-start: var(--space-lg);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .doc-link:hover {
    text-decoration: none;
  }

  .doc-link:hover .arr {
    transform: translateX(3px);
  }

  .doc-link .arr {
    transition: transform var(--dur) var(--ease);
  }
</style>
