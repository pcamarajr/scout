---
// Scout — base layout
//
// Generated by astro-builder. The page shell: every page-view wraps its markup
// in this layout; nothing else declares <html>, landmarks, or <main>.
// Encodes the html-conventions skill: lang from Astro.currentLocale, skip link
// as the first focusable element, header/nav/main/footer landmarks, one <main>.
// The <h1> belongs to the page-view, inside <main> — never here.
//
// The <head> below is the SEO deep module (seo-conventions skill): page-views
// pass only title/description (+ image/type/publishedAt for articles); the
// full title, canonical, OG/Twitter tags, and JSON-LD are derived here from
// Astro.site and the current route. Hand-written SEO tags anywhere else are a
// violation.
//
// i18n NOTE (override): v1 is English-only with `prefixDefaultLocale: false`,
// so routes are unprefixed and `Astro.currentLocale` may be undefined on the
// default-locale routes. We fall back to "en". hreflang alternates are omitted
// while only one locale ships; they return when a second locale is added. RSS
// <link> is omitted until the dated collection + feed lands in phase 2.
import "../styles/global.css";
import ModeToggle from "@components/ModeToggle.astro";
import { createTranslator } from "@lib/i18n";
import { buildHomeUrl, buildLocaleUrl } from "@lib/urls";

interface Props {
  title: string;
  description: string;
  /** Social-share image, root-relative or absolute. Resolved against Astro.site. */
  image?: string;
  /** "website" (default) for index/landing pages, "article" for content entries. */
  type?: "website" | "article";
  /** Set when type is "article" — drives article:published_time and JSON-LD datePublished. */
  publishedAt?: Date;
}

const { title, description, image, type = "website", publishedAt } = Astro.props;

const locale = Astro.currentLocale ?? "en";
const tl = createTranslator(Astro.currentLocale);

const siteName = "Scout";
const pageTitle = `${title} · ${siteName}`;

// Astro.site is mandatory in astro.config.ts — every absolute URL derives from it.
const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = image ? new URL(image, Astro.site) : undefined;

const isHome = Astro.url.pathname === buildHomeUrl(locale);
const jsonLd =
  type === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        description,
        inLanguage: locale,
        mainEntityOfPage: canonical.href,
        ...(publishedAt && { datePublished: publishedAt.toISOString() }),
        ...(socialImage && { image: socialImage.href }),
      }
    : isHome
      ? {
          "@context": "https://schema.org",
          "@type": "WebSite",
          name: siteName,
          url: Astro.site?.href,
          inLanguage: locale,
        }
      : undefined;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Pre-paint observation-mode init — apply the stored choice before first
        paint so there is no flash. No stored value = follow the OS (CSS). */}
    <script is:inline>
      (function () {
        try {
          var m = localStorage.getItem("scout-mode");
          if (m === "day" || m === "night")
            document.documentElement.setAttribute("data-mode", m);
        } catch (e) {}
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale} />
    {socialImage && <meta property="og:image" content={socialImage.href} />}
    {
      type === "article" && publishedAt && (
        <meta
          property="article:published_time"
          content={publishedAt.toISOString()}
        />
      )
    }
    <meta
      name="twitter:card"
      content={socialImage ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage.href} />}
    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body>
    <a href="#main" class="skip-link">{tl("layout.skipToContent")}</a>
    <header class="topbar">
      <div class="wrap topbar-inner">
        <a class="brand" href={buildHomeUrl(locale)} aria-label="Scout home">
          {/* Calibrated-instrument glyph — semantic tokens for the lens/brass
              signal, decorative geometry literal (matches HeroInstrument). */}
          <svg class="glyph" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="12.5" stroke="var(--color-primary)" stroke-width="1.2"></circle>
            <circle cx="14" cy="14" r="7" stroke="var(--color-text-subtle)" stroke-width="1"></circle>
            <circle cx="14" cy="14" r="2.2" fill="var(--color-brass)"></circle>
            <line x1="14" y1="0" x2="14" y2="5" stroke="var(--color-text-subtle)" stroke-width="1"></line>
            <line x1="14" y1="23" x2="14" y2="28" stroke="var(--color-text-subtle)" stroke-width="1"></line>
            <line x1="0" y1="14" x2="5" y2="14" stroke="var(--color-text-subtle)" stroke-width="1"></line>
            <line x1="23" y1="14" x2="28" y2="14" stroke="var(--color-text-subtle)" stroke-width="1"></line>
          </svg>
          <span class="wordmark">Scout</span>
        </a>
        <nav aria-label={tl("layout.mainNav")} class="topnav">
          <a href={buildHomeUrl(locale)}>{tl("nav.home")}</a>
          <a href={`${buildHomeUrl(locale)}#manifesto`}>{tl("nav.manifesto")}</a>
          <a href={`${buildHomeUrl(locale)}#feature`}>{tl("nav.howItWorks")}</a>
          <a href={buildLocaleUrl(locale, "docs")}>{tl("nav.docs")}</a>
          <a href="https://github.com/pcamarajr/scout" rel="noopener">{tl("nav.github")}</a>
          <ModeToggle />
        </nav>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="wrap footer-inner">
        <p class="tagline">{tl("footer.tagline")}</p>
        <nav aria-label={tl("footer.docs")} class="footer-nav">
          <a href={buildLocaleUrl(locale, "docs")}>{tl("footer.docs")}</a>
          <a href="https://www.npmjs.com/package/@pcamarajr/scout">{tl("footer.npm")}</a>
          <a href="https://github.com/pcamarajr/scout">{tl("footer.github")}</a>
        </nav>
        <p class="colophon">
          {tl("footer.builtWith")}{" "}
          <a href="https://github.com/pcamarajr/content-stack" rel="noopener">astro-builder</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  /* ── topbar ── sticky, paper-toned, aligned to the shared .wrap column */
  .topbar {
    position: sticky;
    inset-block-start: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: saturate(1.4) blur(8px);
    border-block-end: 1px solid var(--color-border);
  }

  .topbar-inner {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    block-size: 60px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    letter-spacing: -0.01em;
  }

  .brand:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .glyph {
    inline-size: 26px;
    block-size: 26px;
    flex: none;
  }

  .topnav {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-inline-start: auto;
  }

  .topnav a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .topnav a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  @media (max-width: 720px) {
    .topnav {
      gap: var(--space-md);
    }
    .topnav a {
      font-size: var(--text-xs);
    }
  }

  /* ── footer ── */
  .site-footer {
    margin-block-start: var(--space-3xl);
    border-block-start: 1px solid var(--color-border);
    padding-block: var(--space-2xl);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .tagline {
    margin: 0;
    max-width: 42ch;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .footer-nav {
    display: flex;
    gap: var(--space-md);
    font-size: var(--text-sm);
  }

  .colophon {
    margin: 0;
    margin-inline-start: auto;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    color: var(--color-text-subtle);
  }
</style>
