{
  "name": "@pcamarajr/scout-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @pcamarajr/scout (packages/cli) and its marketing + docs site (packages/site)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pcamarajr/scout.git"
  },
  "author": "Pedro Camara Junior <eu@pcamarajr.dev>",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @pcamarajr/scout",
    "dev": "npm run dev -w @pcamarajr/scout",
    "typecheck": "npm run typecheck -w @pcamarajr/scout",
    "test": "npm run test -w @pcamarajr/scout",
    "smoke": "npm run smoke -w @pcamarajr/scout",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=20"
  }
}
